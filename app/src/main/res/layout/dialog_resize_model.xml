<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <!-- Original size info card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#1A3F51B5"
            app:cardCornerRadius="8dp"
            app:strokeColor="#3F51B5"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Original Model Size (mm)"
                    android:textColor="#9EFFFFFF"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="6dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="X"
                            android:textColor="#7E57C2"
                            android:textSize="11sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/textOriginalX"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="#FFFFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="32dp"
                        android:background="#33FFFFFF"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Y"
                            android:textColor="#26A69A"
                            android:textSize="11sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/textOriginalY"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="#FFFFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="32dp"
                        android:background="#33FFFFFF"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Z"
                            android:textColor="#EF5350"
                            android:textSize="11sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/textOriginalZ"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="#FFFFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- New size input section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Set New Size (mm)"
            android:textColor="#CCFFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <!-- X input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="20dp"
                android:layout_height="wrap_content"
                android:text="X"
                android:textColor="#7E57C2"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginEnd="8dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutX"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Width (mm)">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editSizeX"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:imeOptions="actionNext"
                    android:selectAllOnFocus="true"/>
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Y input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="20dp"
                android:layout_height="wrap_content"
                android:text="Y"
                android:textColor="#26A69A"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginEnd="8dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutY"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Height (mm)">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editSizeY"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:imeOptions="actionNext"
                    android:selectAllOnFocus="true"/>
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Z input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="20dp"
                android:layout_height="wrap_content"
                android:text="Z"
                android:textColor="#EF5350"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginEnd="8dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutZ"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Depth (mm)">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editSizeZ"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:imeOptions="actionDone"
                    android:selectAllOnFocus="true"/>
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Lock aspect ratio checkbox -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/checkLockAspect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lock aspect ratio"
            android:textColor="#CCFFFFFF"
            android:textSize="14sp"
            android:layout_marginBottom="4dp"/>

        <!-- Info hint -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tip: Model units are treated as millimetres (standard for STL/OBJ/PLY from 3D design tools)."
            android:textColor="#66FFFFFF"
            android:textSize="11sp"
            android:layout_marginTop="8dp"/>

    </LinearLayout>
</ScrollView>
